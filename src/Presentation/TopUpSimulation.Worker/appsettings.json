{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "InMemoryDbName": "TopUpWorker",
  "MCITopUpSettings": {
    "BaseUrl": "https://localhost:9090/",
    "SecretToken": "someUser",
    "InstantCharge": "InstantCharge",
    "MockService": true
  },
  "KafkaSettings": {
    "ProducerConfigs": {
      "BootstrapServers": "localhost:9092"
    },
    "ConsumerConfigs": {
      "BootstrapServers": "localhost:9092",
      "GroupId": "worker-group"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ],
    "Properties": {
      "Application": "MyWorker"
    }
  }

}
